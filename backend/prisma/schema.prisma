generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN_MASTER
  ADMIN_COMPANY
  MEMBER
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum CardType {
  BIO_LINK
  DIGITAL_CARD
}

enum UpgradeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FulfillmentStatus {
  WAITING
  PRODUCING
  SHIPPED
  DELIVERED
  ACTIVATED
}

model Company {
  id        String   @id @default(uuid())
  name      String
  email     String
  plan      Plan     @default(FREE)
  active    Boolean  @default(true)
  whatsapp  String?
  city      String?
  state     String?
  industry  String?
  source    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
  cards     Card[]
  upgradeRequests UpgradeRequest[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(ADMIN_COMPANY)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Card {
  id           String   @id @default(uuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  slug         String   @unique
  type         CardType @default(BIO_LINK)
  fullName     String
  jobTitle     String?
  bio          String?
  phone        String?
  whatsapp     String?
  email        String?
  website      String?
  avatarUrl    String?
  avatarShape  String?  @default("circle")
  coverUrl     String?
  companyName  String?
  companyLogoUrl String?
  location     String?
  tagline      String?
  verified     Boolean  @default(false)
  areas        Json?
  primaryColor String?
  accentColor  String?
  bgColor      String?
  nfcSerial    String?  @unique
  nfcUid       String?
  nfcLinkedAt  DateTime?
  socialLinks  Json?
  customButtons Json?
  bannerUrl       String?
  bannerCtaLabel  String?
  bannerCtaUrl    String?
  banners         Json?
  categories      Json?
  products        Json?
  gallery         Json?
  services         Json?
  videos           Json?
  servicesCtaLabel String?
  servicesCtaUrl   String?
  catalogLeadGate  Boolean  @default(false)
  seoTitle     String?
  seoDescription String?
  metaPixelId  String?
  gaId         String?
  template     String   @default("minimal")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  leads        Lead[]
  events       AnalyticsEvent[]
}

model UpgradeRequest {
  id         String        @id @default(uuid())
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy String
  plan       Plan          @default(PRO)
  planProductId String?
  message    String?
  contactPhone String?
  address    String?
  status     UpgradeStatus @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(WAITING)
  trackingCode String?
  carrier    String?
  shippedAt  DateTime?
  deliveredAt DateTime?
  activatedAt DateTime?
  adminNote  String?
  cardId     String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model PlanProduct {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  description  String?
  priceCents   Int      @default(0)
  currency     String   @default("BRL")
  billingCycle String   @default("monthly") // monthly | yearly | one_time
  includesNfc  Boolean  @default(false)
  maxBioLinks  Int      @default(1)
  maxCards     Int      @default(0)
  features     Json?
  active       Boolean  @default(true)
  highlight    Boolean  @default(false)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Lead {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  message   String?
  utmSource String?
  utmMedium String?
  utmCampaign String?
  createdAt DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  cardId    String
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  type      String
  payload   Json?
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Webhook {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  url         String
  secret      String
  events      String[] @default([])
  active      Boolean  @default(true)
  cardSlug    String?
  lastStatus  Int?
  lastError   String?
  lastFiredAt DateTime?
  successCount Int     @default(0)
  failureCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deliveries  WebhookDelivery[]
  @@index([companyId])
}

model WebhookDelivery {
  id         String   @id @default(uuid())
  webhookId  String
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event      String
  payload    Json
  status     Int?
  response   String?
  error      String?
  durationMs Int?
  createdAt  DateTime @default(now())
  @@index([webhookId, createdAt])
}